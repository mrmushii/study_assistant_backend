# Application settings
# These will be loaded via python-dotenv in later steps

# Ollama configuration (Step 5)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Tesseract configuration (Step 2)
# On Windows, set the full path to the tesseract.exe
TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
